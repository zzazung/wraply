default_platform(:android)

# ✅ outputs에서 aab/apk를 "어디서든" 찾아내는 헬퍼
def find_first(glob)
  Dir[glob].sort.first
end

def find_latest(glob)
  files = Dir[glob]
  return nil if files.empty?
  files.max_by { |f| File.mtime(f) }
end

platform :android do
  desc "Build release AAB + APK (signed via key.properties) - universal output detection"
  lane :release do
    project_root = File.expand_path("..", __dir__) # fastlane/의 상위 = 프로젝트 루트
    UI.message("CWD=#{Dir.pwd}")
    UI.message("PROJECT_ROOT=#{project_root}")

    # ✅ 운영형: gradle은 project_root 기준으로 실행 고정
    gradle(
      task: "clean",
      project_dir: project_root,
      print_command: false
    )

    gradle(
      tasks: ["bundleRelease", "assembleRelease"],
      project_dir: project_root,
      print_command: false
    )

    # ✅ 1차: 표준 경로(app 모듈) 먼저 시도
    aab = find_latest("#{project_root}/app/build/outputs/bundle/**/release/*.aab")
    apk = find_latest("#{project_root}/app/build/outputs/apk/**/release/*.apk")

    # ✅ 2차: 모듈명이 app이 아닐 수 있으니 전체 모듈 대상으로 탐색
    # - React Native/Native/멀티모듈 등에서 대응
    aab ||= find_latest("#{project_root}/*/build/outputs/bundle/**/release/*.aab")
    apk ||= find_latest("#{project_root}/*/build/outputs/apk/**/release/*.apk")

    # ✅ 3차: 그래도 없으면 더 넓게(깊게) 탐색 (최후의 안전망)
    aab ||= find_latest("#{project_root}/**/build/outputs/bundle/**/release/*.aab")
    apk ||= find_latest("#{project_root}/**/build/outputs/apk/**/release/*.apk")

    if aab.nil? && apk.nil?
      UI.user_error!("No outputs found (.aab/.apk). Check Gradle tasks and output paths.")
    end

    UI.message("AAB: #{aab || '(none)'}")
    UI.message("APK: #{apk || '(none)'}")

    # ✅ jobRunner 파싱용으로 필요하면 출력 (선택)
    # UI.message("OUTPUT_AAB=#{aab}") if aab
    # UI.message("OUTPUT_APK=#{apk}") if apk
  end
end